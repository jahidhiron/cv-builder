# ─── App ────────────────────────────────────────────────────────────────────
APPLICATION_MODE=production
PORT=8080
API_BASE_URL=https://api.yourdomain.com
CLIENT_BASE_URL=https://yourdomain.com

# ─── API container ──────────────────────────────────────────────────────────
API_CONTAINER_NAME=cv-builder-api

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cv_builder
MIGRATIONS_RUN=true

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ─── Swagger ────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_PROTECTION=true
SWAGGER_USER=swagger-admin
SWAGGER_PASSWORD=change-me

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Mail (Mailgun) ─────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_FROM_NAME=CV Builder
SUPPORT_EMAIL=support@yourdomain.com

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
ENABLE_RABBITMQ=true
RABBITMQ_CONTAINER_NAME=rabbitmq
RABBITMQ_URI=amqp://admin:change-me@rabbitmq:5672
RABBITMQ_QUEUE=cv_builder_queue
RABBITMQ_MANAGEMENT_UI_PORT=15672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me

# ─── Realtime ───────────────────────────────────────────────────────────────
CLIENT_SOCKET_URL=https://yourdomain.com

# ─── Cookie ─────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=yourdomain.com

# ─── Security ────────────────────────────────────────────────────────────────
JWT_MAX_SESSION_DAYS=30
HIBP_CHECK_ENABLED=true

# ─── Cloudflare R2 Storage ──────────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cv-builder-assets
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
