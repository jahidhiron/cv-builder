# App
PORT=8080
APPLICATION_MODE=production
API_BASE_URL="http://localhost:8080"

# If you are using docker
API_CONTAINER_NAME=cv-builder-api

# DB
# PostgreSQL is expected to be a cloud-hosted database (e.g. Neon, Supabase, RDS).
# Set DATABASE_URL to connect. Append ?sslmode=require for cloud providers.
DATABASE_URL=postgresql://postgres:password@localhost:5432/cv_builder

# If not using DATABASE_URL, set individual connection variables instead
PG_HOST=localhost
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=password
PG_DATABASE=cv_builder

# Set MIGRATIONS_RUN to true to automatically run migrations on startup
MIGRATIONS_RUN=true

# Swagger
ENABLE_SWAGGER_PROTECTION=true
SWAGGER_USER=swagger-admin
SWAGGER_PASSWORD=Pass1234?

# RabbitMQ
# If using RabbitMQ as a Docker container, configure the following variables
RABBITMQ_CONTAINER_NAME=rabbitmq
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# If using a local or cloud-based RabbitMQ, set RABBITMQ_URI accordingly
RABBITMQ_URI=amqp://admin:admin@localhost:5672

# These settings are common for both Docker and direct configurations
ENABLE_RABBITMQ=true
RABBITMQ_QUEUE=cv_builder_queue
RABBITMQ_MANAGEMENT_UI_PORT=15672

# Realtime
CLIENT_SOCKET_URL="http://localhost:8080"
